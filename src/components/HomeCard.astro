---
import CustomImage from '@/components/CustomImage'
import FormattedDate from '@/components/FormattedDate'
import ArrowUp from '@/components/icons/ArrowUp'

const { title, description, heroImage, heroVideo, slug, prefetch = true } = Astro.props

const isVideo = !!heroVideo
---

<article class='group mb-10 bg-gray-300 dark:bg-slate-900 w-screen ml-[calc(50%-50vw)]'>
	<div class='relative overflow-hidden w-full h-[70vh]'>
		<a class='block h-full w-full' href={`/${slug}/`} {...(prefetch ? { 'data-astro-prefetch': true } : {})}>
			{
				isVideo ? (
					<video
						autoplay
						muted
						loop
						playsinline
						class='h-full w-full object-cover object-center scale-[100%] hover:scale-[101%] transition-all duration-200'
						preload="metadata"
						key={Astro.url.pathname}
					>
						<source src={heroVideo} type='video/mp4' />
						Your browser does not support the video tag.
					</video>
				) : (
					<CustomImage
						imagePath={heroImage}
						width={1920}
						height={1080}
						class='h-full w-full object-cover object-center scale-[100%] hover:scale-[101%] transition-all duration-200'
						altText={`img of ${title}`}
					/>
				)
			}
		</a>
	</div>

	<div
		class='max-w-6xl mx-auto w-full flex justify-between flex-col gap-4 md:gap-0 py-10 px-5 sm:px-8 lg:px-4 overflow-hidden'
	>
		<div class='flex flex-col gap-3'>
			<div class='flex flex-col gap-2'>
				<a class='text-3xl font-semibold -tracking-wider break-words' href={`/${slug}/`}>
					{title}
				</a>
			</div>

			<p
				class='overflow-hidden text-xl line-clamp-3 text-gray-700 dark:text-white mb-5 font-[400] md:pr-[15%]'
			>
				{description}
			</p>
		</div>

		<footer class='flex justify-between items-center'>
			<a
				href={`/${slug}/`}
				{...(prefetch ? { 'data-astro-prefetch': true } : {})}
				class='flex justify-center items-center dark:text-white rounded-full hover:translate-x-1 transition-transform duration-150 ease-in-out font-semibold gap-1 group'
				aria-label={`go to ${title}`}
			>
				Explore <span
					class='mt-[1px] group-hover:rotate-45 transition-transform duration-250 ease-in-out'
					><ArrowUp width='18' height='18' /></span
				>
			</a>
		</footer>
	</div>
</article>

<script>
	import { animate } from 'motion'

	const images = document.querySelectorAll('img')

	document.addEventListener('DOMContentLoaded', function () {
		const showAnimations = localStorage.getItem('animations') === 'true'

		if (showAnimations) {
			animate(
				'.effect',
				{
					opacity: [0, 1],
					clipPath: ['circle(0% at 0% 0%)', 'circle(100% at 50% 50%)']
				},
				{ duration: 2, easing: 'ease' }
			)
		} else {
			images.forEach((img) => {
				img.classList.remove('opacity-0')
			})
		}
	})
</script>
