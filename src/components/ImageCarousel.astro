---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

interface ImageItem {
	path: string
	alt: string
}

interface Props {
	images: ImageItem[]
}

const { images } = Astro.props

const allImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/**/*.{jpeg,jpg,png,gif,webp}'
)

const resolvedImages = await Promise.all(
	images.map(async (img) => {
		if (!allImages[img.path]) throw new Error(`ImageCarousel: image not found: ${img.path}`)
		const mod = await allImages[img.path]()
		return { src: mod.default, alt: img.alt }
	})
)
---

<div class='w-full max-w-5xl mx-auto px-4 py-10'>
	<image-carousel class='relative block'>
		<!-- slides -->
		<div class='overflow-hidden rounded-lg relative'>
			{
				resolvedImages.map((img, i) => (
					<div class='carousel-slide' data-index={i} style={i === 0 ? '' : 'display:none'}>
						<Image
							src={img.src}
							width={1920}
							height={1080}
							class='w-full h-auto object-cover rounded-lg'
							alt={img.alt}
						/>
					</div>
				))
			}

			<!-- prev button -->
			<button
				class='carousel-prev absolute left-3 top-1/2 -translate-y-1/2 z-10 flex items-center justify-center w-10 h-10 rounded-full bg-black/50 hover:bg-black/75 text-white transition-colors'
				aria-label='Previous image'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					viewBox='0 0 24 24'
					fill='currentColor'
					class='w-5 h-5'
				>
					<path
						fill-rule='evenodd'
						d='M15.28 5.22a.75.75 0 0 1 0 1.06L9.56 12l5.72 5.72a.75.75 0 1 1-1.06 1.06l-6.25-6.25a.75.75 0 0 1 0-1.06l6.25-6.25a.75.75 0 0 1 1.06 0Z'
						clip-rule='evenodd'></path>
				</svg>
			</button>

			<!-- next button -->
			<button
				class='carousel-next absolute right-3 top-1/2 -translate-y-1/2 z-10 flex items-center justify-center w-10 h-10 rounded-full bg-black/50 hover:bg-black/75 text-white transition-colors'
				aria-label='Next image'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					viewBox='0 0 24 24'
					fill='currentColor'
					class='w-5 h-5'
				>
					<path
						fill-rule='evenodd'
						d='M8.72 18.78a.75.75 0 0 1 0-1.06L14.44 12 8.72 6.28a.75.75 0 0 1 1.06-1.06l6.25 6.25a.75.75 0 0 1 0 1.06l-6.25 6.25a.75.75 0 0 1-1.06 0Z'
						clip-rule='evenodd'></path>
				</svg>
			</button>
		</div>

		<!-- caption -->
		<div class='mt-2 text-center text-sm text-gray-500 dark:text-gray-400'>
			{
				resolvedImages.map((img, i) => (
					<span class='carousel-caption' data-index={i} style={i === 0 ? '' : 'display:none'}>
						{img.alt}
					</span>
				))
			}
		</div>

		<!-- dot indicators -->
		{
			resolvedImages.length > 1 && (
				<div class='flex justify-center gap-2 mt-3'>
					{resolvedImages.map((_, i) => (
						<button
							class='carousel-dot w-2.5 h-2.5 rounded-full transition-colors bg-gray-300 dark:bg-gray-600'
							data-index={i}
							aria-label={`Go to image ${i + 1}`}
						/>
					))}
				</div>
			)
		}
	</image-carousel>
</div>

<script>
	class ImageCarousel extends HTMLElement {
		constructor() {
			super()

			const slides = Array.from(this.querySelectorAll<HTMLElement>('.carousel-slide'))
			const captions = Array.from(this.querySelectorAll<HTMLElement>('.carousel-caption'))
			const dots = Array.from(this.querySelectorAll<HTMLElement>('.carousel-dot'))
			let current = 0

			const goTo = (index: number) => {
				slides[current].style.display = 'none'
				captions[current].style.display = 'none'
				dots[current]?.classList.remove('!bg-sky-500')

				current = ((index % slides.length) + slides.length) % slides.length

				slides[current].style.display = ''
				captions[current].style.display = ''
				dots[current]?.classList.add('!bg-sky-500')
			}

			this.querySelector('.carousel-prev')?.addEventListener('click', () => goTo(current - 1))
			this.querySelector('.carousel-next')?.addEventListener('click', () => goTo(current + 1))
			dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)))

			// initialise first dot
			dots[0]?.classList.add('!bg-sky-500')
		}
	}

	if ('customElements' in window) {
		customElements.define('image-carousel', ImageCarousel)
	}
</script>
